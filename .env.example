DATABASE_URL=postgresql://biblehaus:biblehaus_dev@localhost:5432/biblehaus
JWT_SECRET=replace_with_a_long_random_secret

# OpenAI TTS (optional - voice reading disabled if not set)
TTS_ENABLED=false
OPENAI_API_KEY=
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=nova
TTS_SPEED=0.85
TTS_INSTRUCTIONS=Speak slowly and clearly, with short pauses between sentences.
TTS_CACHE_DIR=.cache/tts
